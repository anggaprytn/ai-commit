{
  "name": "ai-commit",
  "version": "2.2.0",
  "type": "module",
  "description": "Make Github commits easier with ChatGPT and Conventional Commits",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "publish:major": "npm version major && npm publish --access public",
    "ollama": "PROVIDER=ollama node dist/index.js"
  },
  "bin": {
    "ai-commit": "./dist/index.js"
  },
  "author": "Insuline.ru <insuline.ru@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "chatgpt": "^5.0.0",
    "dotenv": "^16.0.3",
    "gpt-3-encoder": "^1.1.4",
    "inquirer": "^9.1.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
